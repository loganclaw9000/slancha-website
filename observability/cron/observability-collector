#!/bin/bash
# OpenClaw Observability - Cron Job Entry Point
# Runs every 30 minutes to collect and aggregate metrics

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BASE_DIR="$(dirname "$SCRIPT_DIR")"
SCRIPTS_DIR="$BASE_DIR/scripts"
LOG_FILE="$BASE_DIR/data/cron-log-$(date +%Y%m%d).log"

echo "[$(date)] Starting observability data collection" | tee -a "$LOG_FILE"

# Run data collection
echo "[$(date)] Running collect-metrics.sh" | tee -a "$LOG_FILE"
if bash "$SCRIPTS_DIR/collect-metrics.sh" 2>&1 | tee -a "$LOG_FILE"; then
    echo "[$(date)] Data collection successful" | tee -a "$LOG_FILE"
else
    echo "[$(date)] Data collection failed" | tee -a "$LOG_FILE"
fi

# Run aggregation
echo "[$(date)] Running aggregate-metrics.js" | tee -a "$LOG_FILE"
if node "$SCRIPTS_DIR/aggregate-metrics.js" 2>&1 | tee -a "$LOG_FILE"; then
    echo "[$(date)] Aggregation successful" | tee -a "$LOG_FILE"
else
    echo "[$(date)] Aggregation failed" | tee -a "$LOG_FILE"
fi

echo "[$(date)] Observability collection cycle complete" | tee -a "$LOG_FILE"
