# Slancha API Server Configuration

# Port for the API server
SLANCHA_PORT=3100

# vLLM backend URL
VLLM_URL=http://127.0.0.1:8000

# Supabase (optional — runs in demo mode without these)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# CORS origin (default: * for development)
CORS_ORIGIN=*

# Rate limit (requests per minute per API key)
RATE_LIMIT_RPM=60

# Frontend URL (for Stripe checkout redirect URLs)
FRONTEND_URL=http://localhost:4173

# Stripe (server-side — use SECRET key, not publishable key)
STRIPE_SECRET_KEY=sk_test_your-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret

# Stripe Price IDs (create products in Stripe Dashboard, paste price IDs here)
STRIPE_PRICE_EVAL_DEPLOY_MONTHLY=price_xxx
STRIPE_PRICE_EVAL_DEPLOY_ANNUAL=price_xxx
STRIPE_PRICE_FULL_LOOP_MONTHLY=price_xxx
STRIPE_PRICE_FULL_LOOP_ANNUAL=price_xxx
