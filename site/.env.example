# Environment Configuration
# Copy this file to .env.local and fill in your values

# Application Base URL
VITE_BASE_URL=http://localhost:4173

# Supabase Configuration (Production)
VITE_SUPABASE_URL=your-supabase-url
VITE_SUPABASE_ANON_KEY=your-anon-key

# Contact form uses Supabase `contact_submissions` table directly
# Table: name text, email text, subject text, message text, created_at timestamptz default now()

# Stripe Configuration
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key

# Stripe Payment Links (create these in Stripe Dashboard > Payment Links)
# Each link should have success_url={VITE_BASE_URL}/checkout/success and cancel_url={VITE_BASE_URL}/checkout/cancel
VITE_STRIPE_LINK_EVAL_DEPLOY=https://buy.stripe.com/your-eval-deploy-link
VITE_STRIPE_LINK_FULL_LOOP=
VITE_STRIPE_LINK_SELF_HOSTED=
VITE_STRIPE_LINK_SRE_AGENT=

# Stripe Customer Portal (for managing subscriptions)
VITE_STRIPE_CUSTOMER_PORTAL_URL=https://billing.stripe.com/p/your-portal-link

# Test Environment Variables
VITE_SUPABASE_TEST_URL=https://test.supabase.co
VITE_SUPABASE_TEST_ANON_KEY=test-anon-key
VITE_SUPABASE_SERVICE_ROLE_KEY=test-service-role-key

# Note: Never commit .env.local to version control
# Add .env.local to .gitignore
