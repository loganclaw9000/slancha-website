# Environment Configuration
# Copy this file to .env.local and fill in your values

# Application Base URL
VITE_BASE_URL=http://localhost:4173

# Supabase Configuration (Production)
VITE_SUPABASE_URL=your-supabase-url
VITE_SUPABASE_ANON_KEY=your-anon-key

# Form Endpoint (optional - for contact form API)
VITE_FORM_ENDPOINT=https://your-form-api.com/submit

# Test Environment Variables
VITE_SUPABASE_TEST_URL=https://test.supabase.co
VITE_SUPABASE_TEST_ANON_KEY=test-anon-key
VITE_SUPABASE_SERVICE_ROLE_KEY=test-service-role-key

# Note: Never commit .env.local to version control
# Add .env.local to .gitignore
