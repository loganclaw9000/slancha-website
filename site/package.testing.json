{
  "name": "slancha-testing",
  "version": "1.0.0",
  "description": "Testing suite for Slancha website",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "npm run test:all",
    "test:all": "npm run test:unit && npm run test:components && npm run test:e2e",
    "test:unit": "vitest run --dir __tests__/utils",
    "test:unit:watch": "vitest --dir __tests__/utils",
    "test:components": "vitest run --dir __tests__/components",
    "test:components:watch": "vitest --dir __tests__/components",
    "test:pages": "vitest run --dir __tests__/pages",
    "test:pages:watch": "vitest --dir __tests__/pages",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:a11y": "playwright test --project=accessibility",
    "test:visual": "playwright test --project=visual-regression",
    "test:perf": "playwright test --project=performance",
    "test:db": "node scripts/test-database.js",
    "test:coverage": "vitest run --coverage && playwright test --reporter=html",
    "test:coverage:open": "npm run test:coverage && open coverage/index.html",
    "test:fixtures": "node scripts/seed-test-data.js",
    "test:fixtures:clean": "node scripts/cleanup-test-data.js",
    "test:visual:baseline": "node scripts/generate-baseline.js",
    "test:visual:update": "playwright test --update-snapshots"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^14.2.0",
    "@testing-library/user-event": "^14.5.0",
    "@vitest/coverage-v8": "^1.6.0",
    "jsdom": "^24.0.0",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "@vitest/browser": "^1.6.0"
  }
}
